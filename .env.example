# =============================================================================
# DailyOS environment variables
# Copy to .env.local for local dev. Add the same keys in Vercel → Settings → Env.
# =============================================================================

# REQUIRED for production (SEO, OAuth redirects, sitemap)
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (optional — required only for email/Google sign-in)
# Get from: Supabase → Project Settings → API
# Do NOT use placeholder values in production.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# PostgreSQL (optional — required only for server-side note sync via Prisma)
# Use Supabase connection strings. DIRECT_URL = direct (non-pooler) connection.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# OpenAI (optional — AI assistant degrades gracefully when unset or placeholder)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
